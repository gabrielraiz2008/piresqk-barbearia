{
  "name": "piresqk-barbearia",
  "version": "1.0.0",
  "description": "PiresQK Barbearia - Sistema de Agendamento",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently --kill-others \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@google/maps": "^1.1.3",
    "@sendgrid/mail": "^8.1.6",
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^10.3.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "multer": "^2.0.0",
    "sql.js": "^1.12.0",
    "stripe": "^20.4.0",
    "twilio": "^5.12.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
